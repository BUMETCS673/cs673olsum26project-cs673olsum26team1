# Database — for local development, use your Supabase or local PostgreSQL URL
# When running with Docker, this is overridden by docker-compose.yml
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bariatricpath"

# Firebase Admin SDK — get from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Server — must match VITE_API_URL port in client/.env.local
PORT=5001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"